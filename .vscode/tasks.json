{
	"version": "2.0.0",
	"tasks": [
		// =========================================================================================
		{
			"label": "HOST-TESTS: GNU: Make and run all.",
			"type": "shell",
			"command": "clear && export EMB1_TOOLCHAIN=gnu && make host-tests-run",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		{
			"label": "HOST-TESTS: GNU: Make.",
			"type": "shell",
			"command": "clear && export EMB1_TOOLCHAIN=gnu && make host-tests",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		{
			"label": "HOST-TESTS: GNU: Rebuild and run all.",
			"type": "shell",
			"command": "clear && export EMB1_TOOLCHAIN=gnu && make -B host-tests-run",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		{
			"label": "HOST-TESTS: LLVM: Make.",
			"type": "shell",
			"command": "clear && export EMB1_TOOLCHAIN=llvm && make host-tests",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		{
			"label": "HOST-TESTS: LLVM: Make and run all.",
			"type": "shell",
			"command": "clear && export EMB1_TOOLCHAIN=llvm && make host-tests-run",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		{
			"label": "HOST-TESTS: LLVM: Rebuild and run all.",
			"type": "shell",
			"command": "clear && export EMB1_TOOLCHAIN=llvm && make -B host-tests-run",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		// =========================================================================================
		{
			"label": "HOST-TESTS: Run all integration tests.",
			"type": "shell",
			"command": "clear && pytest -m pctest -k host-tests",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		// =========================================================================================
		{
			"label": "TOOLS: C++: Format all files in the project.",
			"type": "shell",
			"command": "clear && python3 tools/formatter_cpp.py",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		{
			"label": "TOOLS: C++: Format this file.",
			"type": "shell",
			"command": "clear && python3 tools/formatter_cpp.py ${file}",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		// =========================================================================================
		{
			"label": "STM32F051-SBX: Make.",
			"type": "shell",
			"command": "clear && make stm32f051-sbx",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		{
			"label": "STM32F051-SBX: Rebuild.",
			"type": "shell",
			"command": "clear && make -B stm32f051-sbx",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		{
			"label": "STM32H743-SBX: Make.",
			"type": "shell",
			"command": "clear && make stm32h743-sbx",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		{
			"label": "STM32H743-SBX: Rebuild.",
			"type": "shell",
			"command": "clear && make -B stm32h743-sbx",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		// =========================================================================================
		{
			"label": "RIGA-COMM-00: GNU: Make.",
			"type": "shell",
			"command": "clear && export EMB1_TOOLCHAIN=gnu && make riga-comm-00",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		{
			"label": "RIGA-COMM-00: LLVM: Make.",
			"type": "shell",
			"command": "clear && export EMB1_TOOLCHAIN=llvm && make riga-comm-00",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		// =========================================================================================
		//
		// stm32f0-arithmetic-renode
		//
		// =========================================================================================
		{
			"label": "stm32f0-arithmetic-renode: GNU: Make.",
			"type": "shell",
			"command": "clear && export EMB1_TOOLCHAIN=gnu && make -B stm32f0-arithmetic-renode",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		{
			"label": "stm32f0-arithmetic-renode: Start Renode (Telnet, --port 4444)",
			"type": "shell",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}",
			},
			"command": "clear; gnome-terminal --full-screen -- bash -c 'date; pwd; echo; ./3party/renode_portable/renode -p --port 4444 app/stm32f0-arithmetic-renode/stm32f0-arithmetic-renode.resc; echo; echo Renode exited; exec bash'",
			// "command": "clear; gnome-terminal --full-screen -- bash -c 'date; pwd; echo; ./3party/renode_portable/renode --console app/stm32f0-arithmetic-renode/stm32f0-arithmetic-renode.resc; echo; echo Renode exited; exec bash'",
		},
		{
			"label": "stm32f0-arithmetic-renode: GNU: Renode simulation.",
			"type": "shell",
			"command": "clear && python3 app/stm32f0-arithmetic-renode/renode-tests/renode_test.py",
			"group": "build",
			"options": {
				"cwd": "${workspaceFolder}"
			},
		},
		// =========================================================================================
		{
			"label": "python3: Run this file locally.",
			"type": "shell",
			"command": "cd ${fileDirname} && python3 -u ${file}",
			"group": "build",
		},
	]
}
